# --- Tree layout editing (optional) ---
# Public visitors always get a read-only tree unless they know your passphrase.

# Local development: enable save / lock / drag without unlocking
VITE_TREE_EDIT_ENABLED=true

# Production (Vercel): set ONLY in project Environment Variables — do not commit the real value.
# Unlock on the live site via header "Edit layout" or  https://yoursite.vercel.app/?edit=your-phrase
# VITE_TREE_EDIT_PASSPHRASE=choose-a-long-private-phrase
